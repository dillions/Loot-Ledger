# Stripe (Developers -> API keys in your Stripe dashboard)
STRIPE_SECRET_KEY=sk_test_...

# Stripe (Product catalog -> create a recurring price for each paid tier, copy its ID)
STRIPE_PRICE_PLAYERS_GUIDE=price_...
STRIPE_PRICE_COMPLETIONIST=price_...

# The deployed URL of this site (used for Stripe checkout redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# IsThereAnyDeal (register a free app at https://isthereanydeal.com/apps/my/ to get a key)
ITAD_API_KEY=

# Any random long string. Vercel Cron uses this to prove daily-refresh calls
# are legit. Generate one with:  openssl rand -hex 32
CRON_SECRET=

# Only needed if you run scripts/generate-content-drafts.mjs (optional content bot)
ANTHROPIC_API_KEY=
